<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>b9dis.dev</title>

<!-- Tailwind -->
<script src="https://cdn.tailwindcss.com"></script>

<!-- Font -->
<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;500;700&display=swap" rel="stylesheet">

<!-- Particles -->
<script src="https://cdn.jsdelivr.net/npm/particles.js@2.0.0/particles.min.js"></script>

<style>
body {
    font-family: 'Poppins', sans-serif;
    background: #0f172a;
    margin: 0;
    overflow: hidden;
}

/* Particles */
#particles-js {
    position: fixed;
    width: 100%;
    height: 100%;
    z-index: -2;
}

/* Animations */
@keyframes float {
    0% { transform: translateY(0); }
    50% { transform: translateY(-20px); }
    100% { transform: translateY(0); }
}

@keyframes fadeUp {
    from { opacity: 0; transform: translateY(30px); }
    to { opacity: 1; transform: translateY(0); }
}

@keyframes rgbGlow {
    0% { text-shadow: 0 0 20px #ff0080; }
    25% { text-shadow: 0 0 20px #00ffff; }
    50% { text-shadow: 0 0 20px #00ff00; }
    75% { text-shadow: 0 0 20px #ffff00; }
    100% { text-shadow: 0 0 20px #ff0080; }
}

.maintenance-title {
    animation: float 4s ease-in-out infinite, rgbGlow 6s linear infinite, fadeUp 1.2s ease forwards;
}

.sub-text {
    animation: fadeUp 1.5s ease forwards;
    animation-delay: 0.6s;
    opacity: 0;
}

/* ⭐ Stars */
.stars-container {
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: -1;
}

.star {
    position: absolute;
    width: 6px;
    height: 6px;
    background: white;
    clip-path: polygon(
        50% 0%,
        61% 35%,
        98% 35%,
        68% 57%,
        79% 91%,
        50% 70%,
        21% 91%,
        32% 57%,
        2% 35%,
        39% 35%
    );
    opacity: 0;
    animation: starFly linear infinite;
}

@keyframes starFly {
    0% {
        transform: translate(0, 0) scale(0.5) rotate(0deg);
        opacity: 0;
    }
    20% {
        opacity: 1;
    }
    100% {
        transform: translate(var(--x), var(--y)) scale(1.3) rotate(360deg);
        opacity: 0;
    }
}
</style>
</head>

<body>

<div id="particles-js"></div>

<div class="flex items-center justify-center h-screen text-center px-4 relative">
    <div class="relative">
        <div class="stars-container" id="stars"></div>

        <h1 class="maintenance-title text-5xl md:text-7xl font-bold text-white mb-6">
            This website is under maintenance
        </h1>

        <p class="sub-text text-lg md:text-xl text-gray-300">
            I'm currently working on something amazing.<br>
            Please come back soon.
        </p>

        <p class="sub-text text-lg md:text-x0.5 text-gray-300">
            Signed : b9dis
        </p>
    </div>
</div>

<script>
/* Particles */
particlesJS("particles-js", {
    particles: {
        number: { value: 90, density: { enable: true, value_area: 800 } },
        color: { value: "#ffffff" },
        opacity: { value: 0.4, random: true },
        size: { value: 3, random: true },
        line_linked: { enable: true, opacity: 0.2 },
        move: { enable: true, speed: 2 }
    },
    retina_detect: true
});

/* Stars Generator */
const starsContainer = document.getElementById("stars");

function createStar() {
    const star = document.createElement("div");
    star.classList.add("star");

    const angle = Math.random() * Math.PI * 2;
    const distance = 150 + Math.random() * 200;

    star.style.setProperty("--x", `${Math.cos(angle) * distance}px`);
    star.style.setProperty("--y", `${Math.sin(angle) * distance}px`);

    star.style.left = "50%";
    star.style.top = "50%";
    star.style.animationDuration = `${3 + Math.random() * 3}s`;

    starsContainer.appendChild(star);

    setTimeout(() => star.remove(), 6000);
}

setInterval(createStar, 250);
</script>

</body>
</html>